#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
LOG_FILE="/tmp/codex-social-pause-native-host.log"
NODE_BIN="/opt/homebrew/bin/node"

if [ ! -x "$NODE_BIN" ]; then
  NODE_BIN="/usr/local/bin/node"
fi

if [ ! -x "$NODE_BIN" ]; then
  echo "Node executable not found" >> "$LOG_FILE"
  exit 127
fi

exec "$NODE_BIN" "$ROOT_DIR/scripts/codex-native-host.mjs" 2>> "$LOG_FILE"
